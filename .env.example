# ─── Circle Developer-Controlled Wallets ───
# Generate API key in https://console.circle.com/api-keys
CIRCLE_API_KEY=TEST_API_KEY:xxxx:yyyy

# Generate via `generateEntitySecret()` then register via Circle console.
# Store securely — treat like a private key.
CIRCLE_ENTITY_SECRET=your_64_char_hex_entity_secret

# Create a wallet set in the Circle console, paste the ID here.
# All per-order DCWs are created inside this set.
CIRCLE_WALLET_SET_ID=00000000-0000-0000-0000-000000000000

# ─── Merchant ───
# Where unified balance is withdrawn to.
MERCHANT_ADDRESS=0xYOUR_MERCHANT_ADDRESS

# ─── Admin ───
ADMIN_PASSWORD=change_me

# ─── USDC Contract Addresses (Testnet) ───
USDC_ARC_TESTNET=0x3600000000000000000000000000000000000000
USDC_ETH_SEPOLIA=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ARB_SEPOLIA=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
USDC_AVAX_FUJI=0x5425890298aed601595a70AB815c96711a31Bc65
USDC_OP_SEPOLIA=0x5fd84259d66Cd46123540766Be93DFE6D43130D7
USDC_UNICHAIN_SEPOLIA=0x31d0220469e10c4E71834a79b1f276d740d3768F

# ─── RPC URLs (public defaults work, custom RPCs are faster) ───
RPC_ARC_TESTNET=https://rpc.testnet.arc.network
RPC_ETH_SEPOLIA=https://ethereum-sepolia.publicnode.com
RPC_BASE_SEPOLIA=https://base-sepolia-rpc.publicnode.com
RPC_ARB_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
RPC_AVAX_FUJI=https://api.avax-test.network/ext/bc/C/rpc
RPC_OP_SEPOLIA=https://sepolia.optimism.io
RPC_UNICHAIN_SEPOLIA=https://sepolia.unichain.org

# ─── App URL ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
